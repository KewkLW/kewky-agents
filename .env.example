# Agent Dashboard Configuration
# Copy this file to .env and adjust values for your environment.
# All variables are optional — defaults are shown below.

# Server port (default: 3847)
# AGENT_DASH_PORT=3847

# WSL distribution name (default: Ubuntu-24.04)
# WSL_DISTRO=Ubuntu-24.04

# Tailscale hostname for SSH commands shown in the UI (default: localhost)
# TAILSCALE_HOST=my-hostname

# Active team name for claude-teams auto-distribute/nudge (leave empty to disable)
# ACTIVE_TEAM=my-team

# Path to claude-code-teams-mcp repo (required if ACTIVE_TEAM is set)
# TEAMS_MCP_PATH=F:/claude-code-teams-mcp

# Codex home directories (default: ~/.codex and ~/.codex-account-b)
# CODEX_HOME=C:\Users\me\.codex
# CODEX_HOME_ALT=C:\Users\me\.codex-account-b

# Research output directory (default: ./research-output relative to project root)
# RESEARCH_DIR=/path/to/research
